# =============================
# SnapFit Billing Environment
# =============================

# true: mock checkout/approval, false: real PG approval
SNAPFIT_BILLING_MOCK_MODE=true

# Public server URL for return/callback links
SNAPFIT_BILLING_PUBLIC_BASE_URL=https://api.snapfit.example.com

# ---- Toss Payments (NaverPay via PG) ----
# Use test key in staging, live key in production
SNAPFIT_BILLING_TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxx
SNAPFIT_BILLING_TOSS_CONFIRM_URL=https://api.tosspayments.com/v1/payments/confirm
SNAPFIT_BILLING_TOSS_CANCEL_URL_PREFIX=https://api.tosspayments.com/v1/payments

# ---- Webhook signature validation ----
# Global fallback secret
SNAPFIT_BILLING_WEBHOOK_SECRET=
# Provider-specific secrets (recommended)
SNAPFIT_BILLING_WEBHOOK_TOSS_SECRET=
SNAPFIT_BILLING_WEBHOOK_INICIS_SECRET=

# ---- Storage quota limits ----
# Free: 1GB, Pro: 10GB
SNAPFIT_BILLING_STORAGE_LIMIT_FREE_SOFT_BYTES=1073741824
SNAPFIT_BILLING_STORAGE_LIMIT_FREE_HARD_BYTES=1073741824
SNAPFIT_BILLING_STORAGE_LIMIT_PRO_SOFT_BYTES=10737418240
SNAPFIT_BILLING_STORAGE_LIMIT_PRO_HARD_BYTES=10737418240

# ---- Optional profile separation examples ----
# STAGE_BILLING_TOSS_SECRET_KEY=test_sk_...
# PROD_BILLING_TOSS_SECRET_KEY=live_sk_...

# ---- Order delivery/admin ----
SNAPFIT_ORDER_ADMIN_KEY=change_me_order_admin_key
SNAPFIT_ORDER_PRINT_VENDOR=MANUAL

# ---- Order pricing (page-count based) ----
SNAPFIT_ORDER_PRICING_BASE_PAGES=12
SNAPFIT_ORDER_PRICING_MAX_PAGES=50
SNAPFIT_ORDER_PRICING_BASE_PRICE=19900
SNAPFIT_ORDER_PRICING_EXTRA_PAGE_PRICE=700

# ---- Address search API (Juso) ----
# Get key from https://www.juso.go.kr/ (도로명주소 검색 API)
SNAPFIT_ADDRESS_JUSO_ENABLED=true
SNAPFIT_ADDRESS_JUSO_KEY=
SNAPFIT_ADDRESS_JUSO_BASE_URL=https://business.juso.go.kr/addrlink/addrLinkApi.do
SNAPFIT_ADDRESS_JUSO_COUNT_PER_PAGE=10
SNAPFIT_ADDRESS_JUSO_TIMEOUT_MS=4000
SNAPFIT_ADDRESS_JUSO_HISTORY_YN=N
SNAPFIT_ADDRESS_JUSO_FIRST_SORT=road
SNAPFIT_ADDRESS_JUSO_ADD_INFO_YN=Y
